<!DOCTYPE html>
<html lang="<%= config.language%>">
  <%- partial('_partial/head/index') %>
  <body>
    <div id="pjax-loading-overlay"></div>

    <div id="app" tabindex="-1" data-pjax-container>
      <%- partial('_partial/source/cover') %> 
      <%- body %> 
      <%- partial('_partial/source/footer', null, {cache: !config.relative_link}) %>
    </div>
    
    <%- partial('_partial/music-player') %>
    <%- partial('_partial/scripts/index') %>
    
    <script src="https://cdn.jsdelivr.net/npm/pjax@0.2.8/pjax.min.js"></script>
    <script>
      let loadingTimer = null;
      let isLoading = false;
      
      function showLoadingOverlay() {
        isLoading = true;
        loadingTimer = setTimeout(() => {
          const overlay = document.getElementById('pjax-loading-overlay');
          if (overlay && isLoading) {
            overlay.style.display = 'block';
            overlay.offsetHeight; 
            overlay.classList.add('visible');
          }
        }, 300);
      }
      
      function hideLoadingOverlay() {
        isLoading = false;
        if (loadingTimer) {
          clearTimeout(loadingTimer);
          loadingTimer = null;
        }
        const overlay = document.getElementById('pjax-loading-overlay');
        if (overlay) {
          overlay.classList.remove('visible');
          setTimeout(() => {
            if (!isLoading) overlay.style.display = 'none';
          }, 400);
        }
      }
      
      function initPageScripts() {
        if (typeof Waline !== 'undefined') {
          const walineElement = document.querySelector('#waline');
          if (walineElement && !window.walineInstance) {
            window.walineInstance = Waline.init({
              el: '#waline',
              serverURL: walineElement.dataset.serverUrl || '',
              path: window.location.pathname,
              lang: '<%= config.language %>' || 'zh-CN'
            });
          }
        }
        
        const b2tButton = document.getElementById('b2t');
        if (b2tButton) {
          b2tButton.onclick = function(e) {
            e.preventDefault();
            window.scrollTo({ top: 0, behavior: 'smooth' });
          };
        }
      }
      
      if (typeof Pjax !== 'undefined') {
        var pjax = new Pjax({
          // 核心修复：排除所有新窗口打开的链接，这些在手机端最容易导致 Pjax 抓取 URL 失败
          elements: "a[href]:not([target='_blank']):not([data-no-pjax]):not([href^='#']):not([href^='javascript:'])",
          selectors: [
            "title",
            "meta[name=description]",
            "[data-pjax-container]"
          ],
          cacheBust: false,
          scrollTo: false
        });
        
        document.addEventListener('pjax:send', function() {
          showLoadingOverlay();
          if (window.walineInstance) {
            window.walineInstance.destroy();
            window.walineInstance = null;
          }
        });
        
        document.addEventListener('pjax:success', function() {
          initPageScripts();
          hideLoadingOverlay();
        });
        
        document.addEventListener('pjax:error', function(e) {
          hideLoadingOverlay();
          // 手机端拦截 undefined 跳转
          const errUrl = e.requestUrl || (e.detail && e.detail.url);
          if (errUrl && errUrl.indexOf('undefined') === -1) {
            window.location.href = errUrl;
          } else {
            console.error('Pjax blocked an undefined redirect.');
            // 如果点击的是顶栏导致失败，强制刷新当前点击的目标
            if (document.activeElement && document.activeElement.href) {
               window.location.href = document.activeElement.href;
            }
          }
        });
      }
      
      document.addEventListener('DOMContentLoaded', initPageScripts);
    </script>
    
    <style>
      /* 1. 遮罩层 */
      #pjax-loading-overlay {
        position: fixed;
        top: 0; 
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        z-index: 999999;
        display: none;
        opacity: 0;
        transition: opacity 0.4s ease;
        pointer-events: none; 
      }
      #pjax-loading-overlay.visible {
        opacity: 1;
        pointer-events: auto; 
      }
      
      /* 2. 核心修复：防止手机端点击 A 标签内的文字（span/svg）导致无法获取 href */
      .header a *, 
      .navbar__menus a *, 
      .dropdown-menus a * {
        pointer-events: none !important;
      }
      .header a, 
      .navbar__menus a, 
      .dropdown-menus a {
        pointer-events: auto !important;
      }

      @media (prefers-color-scheme: dark) {
        #pjax-loading-overlay {
          background: rgba(18, 18, 18, 0.75);
        }
      }
    </style>
  </body>
</html>