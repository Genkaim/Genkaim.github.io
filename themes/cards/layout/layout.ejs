<!DOCTYPE html>
<html lang="<%= config.language%>">
  <%- partial('_partial/head/index') %>
  
  <!-- Pjax 过渡动画样式 -->
  <style>
    #pjax-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(255, 255, 255, 0.7);
      z-index: 99999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease-out;
      will-change: opacity;
    }

    #pjax-overlay.active {
      opacity: 1;
      pointer-events: all;
    }

    body.pjax-transitioning > #app {
      opacity: 0.3;
      transition: opacity 0.2s ease-out;
      will-change: opacity;
    }

    .cover {
      position: relative;
      z-index: 1;
    }
  </style>
  
  <body>
