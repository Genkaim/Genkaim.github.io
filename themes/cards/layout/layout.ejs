  <!-- Pjax 过渡动画样式 -->
  <style>
    #pjax-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(255, 255, 255, 0.7);
      z-index: 99999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    #pjax-overlay.active {
      opacity: 1;
      pointer-events: all;
    }

    body.pjax-loading {
      opacity: 0.3;
      transition: opacity 0.3s ease;
    }

    body.pjax-loaded {
      opacity: 1;
      transition: opacity 0.3s ease;
    }
  </style>
  
