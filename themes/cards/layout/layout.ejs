    <!-- Pjax 过渡动画蒙版 -->
    <div id="pjax-overlay"></div>

    <div id="app" tabindex="-1" data-pjax-container>
      <%- partial('_partial/source/cover') %> <%- body %> <%-
      partial('_partial/source/footer', null, {cache: !config.relative_link}) %>
    </div>
    
    <%- partial('_partial/music-player') %>
    
    <%- partial('_partial/scripts/index') %>
    
<script>
  /** =========================
   * 全局事件（只绑定一次）
   * ========================= */
  let isGlobalEventsBound = false;

  function bindGlobalEvents() {
    if (isGlobalEventsBound) return;

    /** scroll（控制返回顶部按钮） */
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const btn = document.querySelector("#b2t");
          if (btn) {
            btn.style.opacity = window.scrollY > 100 ? '1' : '0';
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    /** 首页滚动限制（wheel） 
    window.addEventListener("wheel", (event) => {
      if (!window.__IS_HOME__) return;

      const header = document.querySelector(".header");
      if (!header) return;

      const windowHeight = window.innerHeight;
      const headerHeight = header.offsetHeight;
      const targetPosition = windowHeight - headerHeight;
      const scrollTop = window.scrollY;
      const doc_height = document.body.offsetHeight;
      const temp = doc_height - targetPosition * 2;

      if (scrollTop > temp) {
        window.scrollTo({
          top: temp,
          behavior: "auto" // ⚠️ 防止抖动
        });
      }
    }, { passive: true });*/

/** resize（首页封面高度） */
  window.addEventListener("resize", () => {
    if (!window.__IS_HOME__) return;

    const cover = document.querySelector(".cover");
    if (!cover) return;

    // ✅ 关键：resize 不减 header，防止高度抖动 / 累积误差
    cover.style.height = `${window.innerHeight}px`;
  });
    isGlobalEventsBound = true;
  }

  /** =========================
   * 返回顶部按钮
   * ========================= */
  function setupBackToTopButton() {
    const button = document.querySelector("#b2t");
    if (!button) return;

    const newButton = button.cloneNode(true);
    button.parentNode.replaceChild(newButton, button);

    newButton.addEventListener('click', () => {
      newButton.style.opacity = '0';
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  }

  /** =========================
   * 页面初始化（PJAX 每次执行）
   * ========================= */
  function initPageScripts() {
    const currentUrl = window.location.href;

    /** 是否首页 */
    window.__IS_HOME__ =
      currentUrl === window.location.origin + "/" ||
      currentUrl === window.location.origin + "/#" ||
      currentUrl.includes("/page");

    /** KaTeX */
    const postContent = document.querySelector(".post__content");
    if (postContent) {
      const children = postContent.children;
      for (let child of children) {
        if (child.classList.contains("katex-block")) {
          child.style.background = "#f4f4f44d";
          child.style.borderRadius = "7px";

          child.querySelectorAll('.base').forEach(base => {
            base.style.marginBottom = '8px';
            base.style.marginTop = '10px';
          });
        }
      }
    }

/** 首页封面 */
    if (window.__IS_HOME__) {
      const cover = document.querySelector(".cover");
      
      // ✅ 直接在这里为 cover 赋值高度。
      // 因为 initPageScripts 在 DOMContentLoaded 和 Pjax success 时都会执行，
      // 这样就能保证每次（包括直接刷新和 Pjax 切换）进入首页时高度都是正常的。
      if (cover) {
        cover.style.height = `${window.innerHeight}px`;
      }

      /** 首页卡片 */
      const content_card = document.querySelector(".post-list");
      if (content_card?.firstElementChild) {
        content_card.firstElementChild.style.backgroundImage =
          "linear-gradient(to top, white 30%, #a8ede965 100%)";
      }
    }

    /** 返回顶部按钮 */
    setupBackToTopButton();

    /** 归档页 */
    const isArchivesPage =
      currentUrl === window.location.origin + "/archives" ||
      currentUrl === window.location.origin + "/archives/";

    if (isArchivesPage) {
      document.querySelector(".cover")?.style.setProperty("display", "none");
      document.querySelector(".main")?.style.setProperty("top", "100px");
      document.querySelector(".footer")?.style.setProperty("top", "80px");

      document.querySelectorAll(".navbar__menus a").forEach(link => {
        if (link.getAttribute("href") === "/archives/") {
          link.style.backgroundColor = "white";
        }
      });
    }

    /** 代码复制 */
    document.querySelectorAll(".highlight").forEach((highlight) => {
      if (highlight.querySelector(".highlight_header")) return;

      const classes = [...highlight.classList].filter(c => c !== "highlight");
      const table = highlight.querySelector("table");
      if (!table) return;

      if (table.offsetHeight > 500) table.style.height = '500px';

      const div = document.createElement("div");
      div.classList.add("highlight_header");

      const show = document.createElement("text");
      show.textContent = classes[0];
      show.classList.add("highlight_language");

      const button = document.createElement("button");
      button.textContent = "复制";
      button.classList.add("highlight_copy_button");

      const codeContent = table.querySelector(".code").innerText;

      button.addEventListener("click", () => {
        navigator.clipboard.writeText(codeContent).then(() => {
          button.textContent = "✔";
          setTimeout(() => button.textContent = "复制", 2000);
        }).catch(() => {
          button.textContent = "Error";
          setTimeout(() => button.textContent = "复制", 2000);
        });
      });

      div.appendChild(show);
      div.appendChild(button);
      highlight.insertBefore(div, highlight.firstChild);
    });
  }

  /** =========================
   * PJAX
   * ========================= */
  if (typeof Pjax !== 'undefined') {
    new Pjax({
      elements: "a:not([data-no-pjax])",
      selectors: ["title", "[data-pjax-container]"],
      cacheBust: false
    });

    document.addEventListener('pjax:send', () => {
      requestAnimationFrame(() => {
        document.getElementById('pjax-overlay')?.classList.add('active');
        document.body.classList.add('pjax-transitioning');
      });
    });

    document.addEventListener('pjax:success', () => {
      requestAnimationFrame(() => {
        document.body.classList.remove('pjax-transitioning');

        setTimeout(() => {
          document.getElementById('pjax-overlay')?.classList.remove('active');
        }, 200);
      });

      initPageScripts();

      /** Waline */
      const walineContainer = document.querySelector('#waline');
      if (walineContainer) {
        walineContainer.innerHTML = '';
        import('/js/waline.js').then(module => {
          module.init({
            el: '#waline',
            serverURL: 'https://waline.genkaim.top',
          });
        });
      }
    });
  }

  /** =========================
   * 首次加载
   * ========================= */
  document.addEventListener('DOMContentLoaded', () => {
    bindGlobalEvents();   // ✅ 只执行一次
    initPageScripts();    // ✅ 每页执行
  });
</script>
  </body>
</html>